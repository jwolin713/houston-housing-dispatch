# Houston Housing Dispatch - Environment Variables
# Copy this file to .env and fill in your values

# ===== Gmail API =====
GMAIL_CREDENTIALS_FILE=credentials.json
GMAIL_TOKEN_FILE=token.json
HAR_EMAIL_LABEL=HAR Alerts

# ===== Claude API =====
ANTHROPIC_API_KEY=sk-ant-api03-...
CLAUDE_MODEL=claude-sonnet-4-20250514

# ===== Substack =====
SUBSTACK_PUBLICATION_URL=https://houstonhousingdispatch.substack.com
SUBSTACK_COOKIES_PATH=.substack_cookies.enc

# ===== Instagram (Meta Graph API) =====
INSTAGRAM_USER_ID=
INSTAGRAM_ACCESS_TOKEN=

# ===== Email Notifications (Resend) =====
RESEND_API_KEY=re_...
NOTIFICATION_EMAIL=your@email.com

# ===== Application =====
SECRET_KEY=generate-a-secure-random-string-here
DATABASE_URL=sqlite:///data/houston_dispatch.db

# ===== Scheduling =====
CURATION_HOUR=8
MIN_LISTINGS_TO_PUBLISH=10
MAX_LISTINGS_PER_NEWSLETTER=20
APPROVAL_TIMEOUT_HOURS=24

# ===== Timezone =====
TIMEZONE=America/Chicago
